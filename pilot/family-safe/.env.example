# Backend API URL (dev cloud — fill in after provisioning)
EXPO_PUBLIC_API_URL=https://<your-container-app>.azurecontainerapps.io

# Azure AD B2C
AZURE_AD_B2C_TENANT_NAME=<project_name>b2c.onmicrosoft.com
AZURE_AD_B2C_CLIENT_ID=<from-key-vault>
AZURE_AD_B2C_POLICY_NAME=B2C_1_SignUpSignIn

# Database (from Key Vault at startup — do not commit real values)
DATABASE_URL=postgresql://user:password@localhost:5432/family_safe_dev

# Azure Notification Hubs (push-notifications addon)
ANH_CONNECTION_STRING=<from-key-vault>
ANH_HUB_NAME=default
