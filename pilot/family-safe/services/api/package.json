    "fastify":                   "^4.27.0",
    "fastify-plugin":            "^4.5.0",
    "jose":                      "^5.2.0",
    "js-yaml":                   "^4.1.0",
    "pg":                        "^8.11.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node":    "^20.12.0",
    "@types/pg":      "^8.11.0",
    "drizzle-kit":    "^0.20.14",
    "eslint":         "^8.57.0",
