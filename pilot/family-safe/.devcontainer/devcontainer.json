{
  "name": "family-safe-dev",
  "build": { "dockerfile": "Dockerfile" },
  "forwardPorts": [8081, 6006, 3001],
  "portsAttributes": {
    "8081": { "label": "Expo Web" },
    "6006": { "label": "Storybook" },
    "3001": { "label": "API" }
  },
  "postCreateCommand": "npm install",
  "remoteEnv": {
    "CLOUD": "azure",
    "PROJECT_NAME": "family-safe"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  }
}
